{
  "metadata": {
    "id": "IMO-2013-P4",
    "source": "https://www.imo-official.org/assets/documents/problems/2013/2013_eng.pdf",
    "status": "attempt",
    "notes": [
      "Encodes P and Q on line AC and the two angle conditions through similarity constraints.",
      "The side/order hypotheses A between P and C, D interior to BQ, and ray choice for AD are omitted."
    ]
  },
  "steps": [
    {"op": "add_point", "name": "A", "unit_circle": true},
    {"op": "add_point", "name": "B", "unit_circle": true},
    {"op": "add_point", "name": "C", "unit_circle": true},
    {"op": "set_unit_triangle", "args": ["A", "B", "C", "x", "y", "z"]},
    {"op": "add_point", "name": "P"},
    {"op": "add_point", "name": "Q"},
    {"op": "add_collinear", "args": ["A", "C", "P"]},
    {"op": "add_collinear", "args": ["A", "C", "Q"]},
    {"op": "triangle_similarity", "args": ["P", "B", "A", "A", "C", "B"], "directed": false},
    {"op": "triangle_similarity", "args": ["Q", "B", "A", "A", "C", "B"], "directed": false},
    {"op": "add_point", "name": "D"},
    {"op": "add_collinear", "args": ["B", "Q", "D"]},
    {"op": "circle_intersection", "args": ["P", "D", "P", "B", "D_check"], "avoid": ["D"]},
    {"op": "line_circle_intersection", "args": ["A", "D", "O", "A", "R"], "avoid": ["A"]},
    {"op": "constraint_check", "constraint": "squared_distance_equal", "args": ["Q", "B", "Q", "R"]},
    {"op": "print_points", "names": ["A", "B", "C", "P", "Q", "D", "R"]},
    {"op": "learned_rules"},
    {"op": "print_constraints"}
  ]
}
